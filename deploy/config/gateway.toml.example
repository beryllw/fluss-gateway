# Fluss Gateway Example Configuration
# Copy this file to /etc/fluss-gateway/gateway.toml and modify as needed.

[server]
host = "0.0.0.0"
port = 8080
# Maximum request body size in bytes (default: 16MB).
# Clients should inspect the X-Gateway-Max-Body-Size response header
# and split large payloads by row boundaries when a 413 is returned.
max_body_size = 16777216

[fluss]
coordinator = "localhost:9123"

[auth]
# "none"     - use startup credentials for all requests
# "passthrough" - extract per-user credentials from HTTP Basic Auth
type = "none"

[pool]
max_connections = 500
idle_timeout_secs = 600

[log]
level = "info"
